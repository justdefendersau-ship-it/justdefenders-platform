function getSupplierReliability(name:string) {
  const ratings:any = {
    "4WD Industries": 0.95,
    "Landybitz": 0.92,
    "British Auto Parts": 0.90,
    "LR Partshop": 0.88,
    "eBay": 0.75
  };
  return ratings[name] || 0.85;
}

function scorePart(p:any) {

  const price = p.price || 9999;
  const delivery = p.deliveryDays || 5;
  const distance = p.distanceKm || 500;

  const reliability = getSupplierReliability(p.supplier);

  // Weighted scoring (lower = better)
  const score =
    price * 0.6 +
    delivery * 15 +
    distance * 0.5 +
    (1 - reliability) * 200;

  return Math.round(score);
}


function scorePart(p:any) {
  const price = p.price || 9999;
  const delivery = p.deliveryDays || 5;
  const supplierWeight = p.type === "physical" ? 0.9 : p.type === "hybrid" ? 1 : 1.1;

  return Math.round(price * supplierWeight + delivery * 10);
}

