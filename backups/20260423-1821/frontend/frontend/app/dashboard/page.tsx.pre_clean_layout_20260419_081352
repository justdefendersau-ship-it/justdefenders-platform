            </label>
          </div>

        </div>

        {/* RESULTS */}
        {data?.results?.map((s:any,i:number)=>(
          <div key={i} style={{
            background:"#ffffff",
            padding:"18px",
            marginBottom:"16px",
            borderRadius:"12px",
            border:"1px solid #e5e7eb",
            boxShadow:"0 10px 25px rgba(0,0,0,0.08)"
          }}>

            <div style={{display:"flex", alignItems:"center", gap:"10px"}}>
