"use client";

import { useState, useEffect } from "react";

// ======================================================================================
// TOOLTIP
// ======================================================================================

function HelpTooltip({ text }: { text: string }) {
  return (
    <span title={text} style={{
      marginLeft: "6px",
      cursor: "help",
      fontWeight: 700,
      color: "#6b7280"
    }}>
      ?
    </span>
  );
}

// ======================================================================================
// LOGO MAPPING (MATCH YOUR FILES)
// ======================================================================================

function getSupplierLogo(name:string) {
  if (!name) return "/logos/ebay.svg";

  const n = name.toLowerCase();

  if (n.includes("ebay")) return "/logos/ebay.svg";
  if (n.includes("repco")) return "/logos/repco.svg";
  if (n.includes("supercheap")) return "/logos/supercheap.svg";
  if (n.includes("jlr") || n.includes("land rover")) return "/logos/jlr.svg";

  return "/logos/ebay.svg";
}

// ======================================================================================
// IMPROVED VIN DECODER
// ======================================================================================

function decodeVIN(vin:string) {

  if (!vin || vin.length < 10) return null;

  if (vin.startsWith("SALLDHMF")) return { year:"2012", model:"90", engine:"2.2 Puma" };
  if (vin.startsWith("SALLDWBR")) return { year:"2002", model:"110", engine:"Td5" };
  if (vin.startsWith("SALLDHA")) return { year:"1999", model:"90", engine:"Td5" };

  return { year:"Unknown", model:"Defender", engine:"Unknown" };
}

// ======================================================================================
// COMPONENT
// ======================================================================================

export default function Dashboard() {

