          background:"#111827",
          padding:"20px",
          borderRadius:"12px",
          color:"#d1d5db",
          fontSize:"26px",
          fontWeight:800,
          marginBottom:"25px",
          boxShadow:"0 12px 30px rgba(0,0,0,0.4)"
        }}>
          JustDefenders Ã‚Â© Command Centre
        </div>

        {/* CONTROL PANEL */}
        <div style={{
          background:"#ffffff",
          padding:"20px",
          borderRadius:"12px",
          marginBottom:"20px",
          boxShadow:"0 10px 25px rgba(0,0,0,0.08)"
        }}>

          {/* VIN */}
          <div style={{marginBottom:"10px"}}>
            <input
              placeholder="Enter VIN"
              value={vinInput}
              onChange={(e)=>setVinInput(e.target.value.toUpperCase())}
