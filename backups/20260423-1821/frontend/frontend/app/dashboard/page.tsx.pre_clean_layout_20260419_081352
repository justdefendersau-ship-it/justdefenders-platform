          {/* SEARCH */}
          <div>
            <input
              value={query}
              onChange={(e)=>setQuery(e.target.value)}
              style={{padding:"6px", border:"1px solid #ccc", borderRadius:"6px"}}
            />

            <button style={{
              background:"#2563eb",
              color:"#fff",
              padding:"8px 16px",
              borderRadius:"6px",
              marginLeft:"10px",
              fontWeight:600
            }} onClick={search}>
