// ======================================================================================
// VIN DECODER (BASIC - SAFE LOCAL)
// ======================================================================================

function decodeVIN(vin:string) {

  if (!vin || vin.length < 10) return null;

  // Basic Defender rules (expand later)
  if (vin.startsWith("SALLDH")) {
    return { year: "2012", model: "90", engine: "2.2" };
  }

  if (vin.startsWith("SALLDW")) {
    return { year: "2002", model: "110", engine: "Td5" };
  }

  if (vin.startsWith("SALLDHA")) {
    return { year: "1999", model: "90", engine: "Td5" };
  }

  return { year: "Unknown", model: "Defender", engine: "Unknown" };
}


function HelpTooltip({ text }: { text: string }) {
  return (
    <span title={text} style={{
      marginLeft: "6px",
      cursor: "help",
      fontWeight: 700,
      color: "#6b7280"
    }}>
      ?
    </span>
  );
}
