const supplierLogos:any = {
  "eBay": "/logos/ebay.svg",
  "JLR": "/logos/jlr.svg",
  "Jaguar Land Rover": "/logos/jlr.svg",
  "Repco": "/logos/repco.svg",
  "Supercheap": "/logos/supercheap.svg"
};

function getSupplierLogo(name:string) {
  if (!name) return "/logos/ebay.svg";

  const key = Object.keys(supplierLogos).find(k =>
    name.toLowerCase().includes(k.toLowerCase())
  );

  return key ? supplierLogos[key] : "/logos/ebay.svg";
}

function scorePart(p:any) {
  const price = p.price || 9999;
  const distance = p.distanceKm || 500;
  return Math.round(price * 0.7 + distance * 0.3);
}

