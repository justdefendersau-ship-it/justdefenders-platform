"use client";

import { useState, useEffect } from "react";

export default function Dashboard() {

function enrichResults(results) {
  return results.map((s:any) => {

    const stock = getStockStatus();
    const delivery = getDeliveryScore();
    const score = scorePart(s.price, stock.label, s.supplier);

    return {
      ...s,
      stock,
      delivery,
      score
    };
  });
}


function explainScore(s) {

  if (!s || !s.stock) return "Evaluating part...";

  let reasons = [];

  if (s.price === Math.min(...data.results.map(r=>r.price))) {
    reasons.push("Lowest price available");
  }

  if (s.stock?.label === "In Stock") {
    reasons.push("Available immediately");
  }

  const trust = supplierTrust[s.supplier] || 0.75;
  if (trust > 0.9) {
    reasons.push("Highly trusted supplier");
  }

  if (s.score > 1300) {
    reasons.push("Excellent overall value");
  }

  return reasons.join(" Ã¢â‚¬Â¢ ");
}

function confidenceScore(score) {
  if (score > 1400) return "High Confidence";
  if (score > 1100) return "Medium Confidence";
  return "Low Confidence";
}




const supplierTrust:any = {
  "Repco": 0.95,
  "Supercheap Auto": 0.90,
  "eBay": 0.70,
  "Generic Supplier": 0.75
};

function getDeliveryScore() {
  const rand = Math.random();

  if (rand > 0.7) return { label: "Fast Delivery", score: 200 };
  if (rand > 0.4) return { label: "Standard Delivery", score: 100 };
  return { label: "Slow Delivery", score: -100 };
}

function scorePart(price, stockLabel, supplier) {

  let score = 0;

  // Price
  score += (1000 - price);

  // Stock
  if (stockLabel === "In Stock") score += 500;
  if (stockLabel === "Low Stock") score += 200;
  if (stockLabel === "Out of Stock") score -= 500;

  // Trust
  const trust = supplierTrust[supplier] || 0.75;
  score += trust * 500;

  // Delivery
  const delivery = getDeliveryScore();
  score += delivery.score;

  return score;
}

function getStockStatus() {
  const rand = Math.random();

  if (rand > 0.6) return { label: "In Stock", color: "#16a34a" };
  if (rand > 0.3) return { label: "Low Stock", color: "#f59e0b" };
  return { label: "Out of Stock", color: "#dc2626" };
}


