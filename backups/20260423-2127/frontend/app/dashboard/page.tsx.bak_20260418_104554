          padding: "8px 10px",
          borderRadius: "6px",
          fontSize: "12px",
          whiteSpace: "nowrap",
          boxShadow: "0 6px 18px rgba(0,0,0,0.2)",
          zIndex: 999
        }}>
          {text}
        </div>
