import { NextResponse } from "next/server";
import { getCompatibleParts, getUpgrades } from "@/lib/compatibility";
import { fetchAllSuppliers } from "@/lib/suppliers";


const memberDiscounts:any = {
  "Repco": 0.12,
  "Supercheap Auto": 0.10,
  "Burson": 0.08,
  "4WD Industries": 0.05,
  "Landybitz": 0.07
};


function calculateScore(item:any, minPrice:number, maxDistance:number) {

  const price = item.memberPrice || item.price;
  const priceScore = (1 / price) * 10000;

  const distance = item.distance || maxDistance;
  const distanceScore = maxDistance > 0 ? ((maxDistance - distance) / maxDistance) * 100 : 0;

  const speedScore = item.deliveryDays ? (10 - item.deliveryDays) * 5 : 0;

  const discountBonus = item.memberPrice ? 20 : 0;

  return Math.round(priceScore + distanceScore + speedScore + discountBonus);
}

