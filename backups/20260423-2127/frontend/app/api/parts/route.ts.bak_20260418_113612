      type: "hybrid",
      location: null
    }
  };

  // ----------------------------------------------------------------------------------
  // ENRICH RESULTS
  // ----------------------------------------------------------------------------------

  const enriched = results.map(r => {

  const discount = memberDiscounts[r.supplier];

  let memberPrice = null;

  if (discount) {
    memberPrice = Math.round(r.price * (1 - discount));
  }

  return {
    ...r,
    memberPrice
  };
});

  
const prices = enriched.map((r:any) => r.memberPrice || r.price);
const minPrice = Math.min(...prices);

const maxDistance = Math.max(...enriched.map((r:any) => r.distance || 0), 1);

// Calculate score
const scored = enriched.map((r:any) => {
  const distance = r.location ? 100 : 500; // fallback until real distance passed in
  const score = calculateScore({...r, distance}, minPrice, maxDistance);

  return {
    ...r,
    score,
    distance
  };
});

// Determine labels
const bestScore = Math.max(...scored.map((r:any) => r.score));
const cheapest = Math.min(...scored.map((r:any) => r.memberPrice || r.price));

const final = scored.map((r:any) => {

  let label = null;

  if (r.score === bestScore) label = "BEST VALUE";
  else if ((r.memberPrice || r.price) === cheapest) label = "CHEAPEST";
  else if (r.deliveryDays && r.deliveryDays <= 2) label = "FASTEST";

  return {
    ...r,
    label
  };
});

const extended = final.flatMap((r:any) => {

  const compatible = getCompatibleParts(r.partNumber).map((c:any) => ({
    supplier: c.brand,
    partNumber: c.partNumber,
    price: Math.round(r.price * 0.9),
    type: "compatible",
    original: r.partNumber
  }));

  const upgrades = getUpgrades(r.partNumber).map((u:any) => ({
    supplier: u.brand,
    partNumber: u.partNumber,
    price: Math.round(r.price * 1.4),
    type: "upgrade",
    note: u.note
  }));

  return [r, ...compatible, ...upgrades];
});

return NextResponse.json({
  query,
  vin,
  results: extended
});
}